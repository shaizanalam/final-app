{
  "version": 3,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "/logo.png",
      "dest": "/dist/client/logo.png"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.js"
    }
  ],
  "outputDirectory": "dist/client"
}
